{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reverse-editing.local/schemas/voiceover_script.schema.json",
  "title": "Editable voiceover script",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "created_at",
    "language",
    "source_files",
    "voiceover_policy",
    "segment_count",
    "segments"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "content-layer-mvp-v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "language": {
      "type": "string",
      "examples": ["zh-CN"]
    },
    "source_files": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "copy_script",
        "shot_index"
      ],
      "properties": {
        "copy_script": {
          "type": "string"
        },
        "shot_index": {
          "type": "string"
        },
        "current_preview_manifest": {
          "type": "string"
        },
        "replacement_plan": {
          "type": "string"
        }
      }
    },
    "voiceover_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "editable_script_required",
        "real_timing_required_before_final_subtitles",
        "allowed_timing_sources",
        "no_audio_generated_in_mvp"
      ],
      "properties": {
        "editable_script_required": {
          "type": "boolean",
          "const": true
        },
        "real_timing_required_before_final_subtitles": {
          "type": "boolean",
          "const": true
        },
        "allowed_timing_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "tts_word_boundary",
              "tts_speech_marks",
              "forced_alignment",
              "manual_reviewed_alignment",
              "estimated_placeholder"
            ]
          },
          "uniqueItems": true
        },
        "no_audio_generated_in_mvp": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "voice_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "voice_name": {
          "type": ["string", "null"]
        },
        "gender_presentation": {
          "type": ["string", "null"]
        },
        "age_style": {
          "type": ["string", "null"]
        },
        "accent_or_region": {
          "type": ["string", "null"]
        },
        "delivery_style": {
          "type": ["string", "null"]
        }
      }
    },
    "timeline_source": {
      "type": "string",
      "enum": [
        "shot_index_reviewed",
        "current_preview_manifest",
        "voiceover_alignment"
      ]
    },
    "segment_count": {
      "type": "integer",
      "minimum": 1
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/voiceSegment"
      }
    }
  },
  "$defs": {
    "voiceSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "voice_segment_id",
        "shot_id",
        "script",
        "tone",
        "target_duration_ms",
        "pause_after_ms",
        "timing_source",
        "alignment_status",
        "editable",
        "status"
      ],
      "properties": {
        "voice_segment_id": {
          "type": "string",
          "pattern": "^vo_[0-9]{3}(_[0-9]{2})?$"
        },
        "shot_id": {
          "type": "string",
          "pattern": "^shot_[0-9]{3}$"
        },
        "script": {
          "type": "string",
          "minLength": 1
        },
        "tone": {
          "type": "string",
          "minLength": 1
        },
        "target_duration_ms": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "pause_before_ms": {
          "type": "integer",
          "minimum": 0
        },
        "pause_after_ms": {
          "type": "integer",
          "minimum": 0
        },
        "shot_fit_policy": {
          "type": "string",
          "enum": [
            "fit_inside_shot",
            "may_continue_across_shots",
            "requires_shot_extension",
            "requires_copy_shortening"
          ]
        },
        "tts_provider": {
          "type": "string",
          "enum": [
            "pending",
            "human_recording",
            "amazon_polly",
            "azure_speech",
            "google_cloud_tts",
            "elevenlabs",
            "other"
          ]
        },
        "timing_source": {
          "type": "string",
          "enum": [
            "tts_word_boundary",
            "tts_speech_marks",
            "forced_alignment",
            "manual_reviewed_alignment",
            "estimated_placeholder"
          ]
        },
        "alignment_status": {
          "type": "string",
          "enum": [
            "pending",
            "estimated",
            "aligned",
            "needs_real_audio",
            "needs_review"
          ]
        },
        "editable": {
          "type": "boolean",
          "const": true
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "needs_review",
            "approved",
            "rejected"
          ]
        }
      }
    }
  }
}
